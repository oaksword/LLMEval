# LLMEval Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Default Provider (used when no provider prefix in model name) ──
LLMEVAL_API_KEY=sk-your-default-key-here
LLMEVAL_BASE_URL=https://api.openai.com/v1

# ── Named Providers ──
# Format: LLMEVAL_<NAME>_API_KEY and LLMEVAL_<NAME>_BASE_URL
# Falls back to <NAME>_API_KEY (e.g. DEEPSEEK_API_KEY from .zshrc)

# DeepSeek
# Built-in cache-aware pricing is applied automatically:
#   flash: cache_hit=$0.0028/M  cache_miss=$0.14/M  output=$0.28/M
#   pro:   cache_hit=$0.003625/M  cache_miss=$0.435/M  output=$0.87/M (75% discount until 2026-05-31)
# LLMEVAL_DEEPSEEK_API_KEY=sk-deepseek-key
# LLMEVAL_DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter
# LLMEVAL_OPENROUTER_API_KEY=sk-or-key
# LLMEVAL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AIHubMix (aggregator; base URL is built-in: https://aihubmix.com/v1)
# Use EXACT model IDs copied from https://aihubmix.com/models — unknown IDs
# silently fall back to a different model.
# AIHubMix does NOT return cost in the API response and is not in the built-in
# pricing tables, so cost shows N/A unless you add a manual :price=in,out override.
#   e.g. --models "aihubmix/claude-sonnet-4-6:price=3.00,15.00"
# LLMEVAL_AIHUBMIX_API_KEY=sk-aihubmix-key

# ── Default models (comma-separated) ──
# Override with --models on the command line.
# Format: [provider/]model_id[:reasoning=high|max][:price=in,out]
LLMEVAL_MODELS=gpt-4o

# Examples:
# LLMEVAL_MODELS=deepseek/deepseek-v4-flash,openrouter/qwen/qwen3.6-flash
# LLMEVAL_MODELS=deepseek/deepseek-v4-pro:reasoning=max
